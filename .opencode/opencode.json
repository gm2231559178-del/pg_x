{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "pgx": {
      "type": "local",
      "command": ["./target/release/pgx", "mcp", "--transport", "stdio"],
      "enabled": true,
      "environment": {
        "DATABASE_URL": "postgres://postgres:postgres@localhost:5432/postgres"
      },
      "timeout": 10000
    },
    "pgx-remote": {
      "type": "remote",
      "url": "http://127.0.0.1:3100/mcp",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer <your-token>"
      }
    },
    "pgx-oidc": {
      "type": "remote",
      "url": "http://127.0.0.1:3100/mcp",
      "enabled": false,
      "oauth": {}
    }
  }
}
