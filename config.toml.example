default = "local"

# GraphQL resolver mappings — maps field names to SQL queries.
# Used by the `listen elasticsearch`, `graphql`, and `consume` subcommands.
# [resolvers.material]
# sql = "SELECT mat_no, name, description FROM materials WHERE mat_no = ANY($1)"
# param = "mat_no"
# batch_by = "mat_no"
#
# [resolvers.sizes]
# sql = "SELECT mat_no, size_code, name FROM sizes WHERE mat_no = ANY($1)"
# param = "mat_no"
# batch_by = "mat_no"
# connection = "staging"

[connections.local]
url = "postgres://postgres:secret@localhost:5432/mydb"
description = "Local dev database"

[connections.local.listen]
channels = ["user_updates"]
max_reconnect_attempts = 5
reconnect_base_ms = 2000
reconnect_max_ms = 60000

[connections.local.listen.sink]
type = "shell"
command = "echo [$PGX_CHANNEL] $PGX_PAYLOAD"
mode = "simple"

# pgx consume examples:
#
# Consume from RabbitMQ, GraphQL compose, index to Elasticsearch:
#
# [connections.local.consume]
# source = { type = "rabbitmq", amqp_url = "amqp://guest:guest@localhost:5672/%2F", queue = "pgx-events" }
# sink = { type = "elasticsearch", url = "http://localhost:9200", index = "materials", id_field = "mat_no" }
# query_mode = "contract"
# max_depth = 8
# on_error = "lenient"
#
# Consume from Kafka with simple (fixed query) mode:
#
# [connections.staging.consume]
# source = { type = "kafka", brokers = "kafka:9092", topic = "orders", group_id = "pgx" }
# sink = { type = "webhook", url = "https://hooks.example.com/orders" }
# query_mode = "simple"
# query = "OrderFull"
# on_error = "strict"
#
# Consume and store in Redis:
#
# [connections.local.consume]
# source = { type = "rabbitmq", amqp_url = "amqp://guest:guest@localhost:5672/%2F", queue = "pgx-events" }
# sink = { type = "kv", url = "redis://localhost:6379", key_field = "id", key_prefix = "pgx:", ttl = 3600 }
# query_mode = "contract"
#
# Consume and store in Memcached:
#
# [connections.local.consume]
# source = { type = "rabbitmq", amqp_url = "amqp://guest:guest@localhost:5672/%2F", queue = "pgx-events" }
# sink = { type = "kv", url = "memcached://localhost:11211", key_field = "id", key_prefix = "pgx:" }
# query_mode = "contract"

[connections.local.replicate]
slot = "my_slot"
publications = ["my_pub"]
temporary = true
max_reconnect_attempts = 10
reconnect_base_ms = 1000
reconnect_max_ms = 60000

[connections.local.replicate.sink]
type = "stdout"
pretty = true

# Fan-out to multiple sinks:
# [[connections.local.replicate.additional_sinks]]
# type = "webhook"
# url = "https://hooks.example.com/events"

[connections.staging]
url = "postgres://user:pass@staging.host:5432/stagingdb"
description = "Staging"

# NOTE: Production credentials should be provided via DATABASE_URL env var or
# ~/.pgx/config.toml (which is excluded from version control). Do not commit
# real passwords to this file. Example:
#
# [connections.prod]
# url = "postgres://readonly:pass@prod.host:5432/proddb"
# description = "Production (read-only replica)"
#
# [connections.prod.listen]
# channels = ["admin_alerts"]
#
# [connections.prod.listen.sink]
# type = "webhook"
# url = "https://hooks.example.com/pgx"
# mode = "contract"
#
# [connections.prod.consume]
# source = { type = "rabbitmq", amqp_url = "amqp://rabbitmq:5672/%2F", queue = "events" }
# sink = { type = "elasticsearch", url = "http://es:9200", index = "alerts" }
# query_mode = "contract"
# on_error = "strict"
#
# [connections.prod.replicate]
# slot = "prod_slot"
# publications = ["prod_pub"]
# tables = ["public.orders"]
# ops = ["insert", "update"]
#
# # Apply to PostgreSQL + forward to Kafka simultaneously
# [connections.prod.replicate.sink]
# type = "postgres"
# target_url = "postgres://user:pass@replica:5432/db"
# batch_size = 500
#
# [[connections.prod.replicate.additional_sinks]]
# type = "kafka"
# brokers = "kafka-prod:9092"
# topic = "pgx-wal"
